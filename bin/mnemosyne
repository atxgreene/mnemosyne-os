#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import webbrowser
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from mnemosyne.core.memory import MemoryStore
from mnemosyne.skills.store import SkillStore
from mnemosyne.tugboat.router import TugboatRouter


def home() -> Path:
    configured = os.environ.get("MNEMOSYNE_HOME")
    if configured:
        return Path(configured)
    return Path.home() / ".mnemosyne"


def stores() -> tuple[MemoryStore, SkillStore]:
    return MemoryStore(home() / "memory.jsonl"), SkillStore(home() / "skills.json")


def emit(data, as_json: bool) -> None:
    if as_json:
        print(json.dumps(data, indent=2))
    else:
        if isinstance(data, list):
            for item in data:
                print(f"- {item.get('content') or item.get('name')}: {item.get('metadata') or item.get('description', '')}")
        else:
            print(data)


def main() -> int:
    parser = argparse.ArgumentParser(prog="mnemosyne", description="Mnemosyne OS local cognitive-core helper")
    sub = parser.add_subparsers(dest="command", required=True)

    p_store = sub.add_parser("store", help="Store a memory")
    p_store.add_argument("content")
    p_store.add_argument("--domain", default="general")
    p_store.add_argument("--importance", default="medium")
    p_store.add_argument("--json", action="store_true")

    p_search = sub.add_parser("search", help="Search memory")
    p_search.add_argument("query")
    p_search.add_argument("--limit", type=int, default=8)
    p_search.add_argument("--json", action="store_true")

    p_route = sub.add_parser("route", help="Route a goal through Tugboat")
    p_route.add_argument("goal")
    p_route.add_argument("--json", action="store_true")

    p_graph = sub.add_parser("graph", help="Print the memory graph")
    p_graph.add_argument("--json", action="store_true")

    sub.add_parser("dashboard", help="Open the local dashboard")
    sub.add_parser("serve", help="Run the FastAPI server on port 8765")

    args = parser.parse_args()
    memory, skills = stores()

    if args.command == "store":
        entry = memory.add_memory(args.content, {"domain": args.domain, "importance": args.importance})
        if args.json:
            emit(entry.to_dict(), True)
        else:
            print(f"stored {entry.id}")
        return 0

    if args.command == "search":
        emit([entry.to_dict() for entry in memory.search(args.query, args.limit)], args.json)
        return 0

    if args.command == "route":
        emit(TugboatRouter(memory, skills).route(args.goal), args.json)
        return 0

    if args.command == "graph":
        emit(memory.graph(), args.json)
        return 0

    if args.command == "dashboard":
        webbrowser.open((ROOT / "dashboard" / "mnemosyne-panels.html").resolve().as_uri())
        print("opened dashboard")
        return 0

    if args.command == "serve":
        return subprocess.call([sys.executable, "-m", "uvicorn", "mnemosyne.services.api_server:app", "--host", "0.0.0.0", "--port", "8765"], cwd=ROOT)

    return 1


if __name__ == "__main__":
    raise SystemExit(main())
